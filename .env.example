# Copy to .env and fill in. Used by docker run --env-file .env
HUB_TOKEN=change-me-to-a-long-random-secret
HUB_PORT=4790

# Verbose per-frame diagnostic logging (ACT/REPORT/SESSION at ~1 Hz). Off by
# default; set to true only when debugging playback state.
HUB_DEBUG=false

# Navidrome — for the optional savePlayQueue mirror (lets unmodified Subsonic
# clients resume where you left off). Mirror is single-user, so give it creds.
NAVIDROME_URL=https://navidrome.example.com
HUB_MIRROR_PLAYQUEUE=true
HUB_ND_USER=your-navidrome-username
HUB_ND_PASS=your-navidrome-password
